# LLM API keys
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Which provider to try first (groq | gemini)
LLM_PROVIDER=groq

# Playwright headless mode (false on first login to save cookies)
HEADLESS=true

# Optional residential proxy (leave blank to disable)
PROXY_URL=

# Dashboard API
API_PORT=8000

# Dry-run mode (true = log actions but do not post/follow)
DRY_RUN=false
