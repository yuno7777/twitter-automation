# LLM API keys
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Which provider to try first (groq | gemini)
LLM_PROVIDER=groq

# 3-tier model cascade — primary -> fallback -> different-provider last resort
GROQ_PRIMARY_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.5-flash

# Playwright headless mode (false on first login to save cookies)
HEADLESS=true

# Optional residential proxy (leave blank to disable)
PROXY_URL=

# Dashboard API
API_PORT=8000

# Dry-run mode (true = log actions but do not post/follow)
DRY_RUN=false

# Your niche (drives all content)
NICHE=AI agents, automation, and what actually works in production
X_HANDLE=your_handle_no_at
PEAK_HOURS=9,10,13,14,19,20,21

# Comma-separated X handles (no @) — bot scrapes their top tweets each cycle for style reference
CREATORS_TO_STUDY=swyx,levelsio,nutlope
